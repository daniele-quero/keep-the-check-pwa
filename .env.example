# Server-side AI provider keys for the Netlify Functions proxy.
# Set these as Netlify Environment Variables (Site settings > Environment variables)
# or in a local .env file when running `netlify dev`.
# Never commit real keys. These are placeholders only.
#
# Convention: AI_KEY_<PROVIDER_ID_UPPER_SNAKE>. Only providers whose key is set
# become selectable in the app. The browser never receives these values.

AI_KEY_GOOGLE_GEMINI=your_google_gemini_key_here
AI_KEY_GROQ=your_groq_key_here
AI_KEY_MISTRAL=your_mistral_key_here
AI_KEY_OPENROUTER=your_openrouter_key_here
AI_KEY_HUGGINGFACE=your_huggingface_key_here
AI_KEY_XAI_GROK=your_xai_grok_key_here
AI_KEY_CEREBRAS=your_cerebras_key_here
